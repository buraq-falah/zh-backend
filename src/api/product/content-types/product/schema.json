{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer"
    },
    "imageUrl": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "T-Shirts",
        "Shirts",
        "Hats",
        "Accessories",
        "Shorts",
        "Sports"
      ]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Men",
        "Women",
        "Accessories",
        "Hats",
        "Sports"
      ]
    },
    "description": {
      "type": "text"
    }
  }
}
